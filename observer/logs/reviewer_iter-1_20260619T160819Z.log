   181	"
   182	
   183	# 2-d. 用轻量 API 调用测试 key 有效性 (以 Anthropic 为例)
   184	# 仅当 ANTHROPIC_API_KEY 已设置时执行
   185	if [ -n "$ANTHROPIC_API_KEY" ]; then
   186	    echo "=== Testing key against api.anthropic.com ==="
