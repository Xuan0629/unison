# import json
# c = json.load(open('$HOME/.openclaw/openclaw.json'))
# c['agents']['defaults']['model'] = 'claude-sonnet-4-6'  # 正确的 model ID
# json.dump(c, open('$HOME/.openclaw/openclaw.json','w'), indent=2)
# "

# 修复 2: 修正 provider baseUrl
# python3 -c "
# import json
# c = json.load(open('$HOME/.openclaw/openclaw.json'))
# c['models']['providers']['anthropic']['baseUrl'] = 'https://api.anthropic.com/v1'
# json.dump(c, open('$HOME/.openclaw/openclaw.json','w'), indent=2)
# "

# 修复 3: 添加新 provider (如果目标 model 属于不同 provider)
# 手动在 openclaw.json::models.providers 添加 entry, 参考已有 provider 格式
```

## 标准诊断流程

执行顺序: **先诊断、后修复、修复前备份、修复后验证。**

```bash
# 0. 记录初始状态
echo "=== openclaw-model-debug: $(date -Is) ==="
echo "Error observed: <copy from agent output>"

# 1. 按症状匹配场景 (选择最匹配的场景序号: 1/2/3/4)
#    多个症状 → 按优先级: 认证(2) > 可达性(1) > 404(4) > 超时(3)

# 2. 运行对应场景的诊断命令
#    每个场景的诊断是独立的 — 不需要全部运行

# 3. 按诊断决策树判断根因
#    - 能自修复 → 继续步骤 4
#    - 需 operator → 跳到 "升级路径" 一节

# 4. 备份所有将被修改的文件
TS=$(date +%Y%m%d-%H%M%S)
for f in ~/.openclaw/openclaw.json ~/.openclaw/agents/main/agent/auth-profiles.json; do
    [ -f "$f" ] && cp "$f" "$f.bak.$TS"
done

# 5. 执行修复 (只改一个配置项, 改完验证再改下一个)

# 6. 验证
python3 -c "
import json
json.load(open('$HOME/.openclaw/openclaw.json'))
print('openclaw.json: valid JSON')
"
# 重跑对应场景的诊断命令确认修复生效

# 7. 记录 diff
for f in ~/.openclaw/openclaw.json ~/.openclaw/agents/main/agent/auth-profiles.json; do
    BAK="$f.bak.$TS"
    [ -f "$BAK" ] && echo "=== diff $f ===" && diff -u "$BAK" "$f"
done
```

## 升级路径 (Escalation)

以下情况 **停止自修复, 告知 operator**:

| 情况 | 升级信息 |
|------|---------|
| DNS 解析失败且非本机 `/etc/hosts` 问题 | "DNS cannot resolve `<host>`. Check network DNS configuration." |
| API key 被吊销 (401 且 key 格式正确) | "API key for provider `<name>` has been revoked. Regenerate at provider console." |
| 账号无 model 权限 (model 列表不包含目标 model) | "Model `<model>` is not available for this account. Enable it in provider console." |
| 私有部署不可达 (Azure / 私有 endpoint 404) | "Custom deployment for `<model>` at `<baseUrl>` not found. Verify deployment exists." |
| 多次修复后仍然失败 (>3 次) | "Diagnostic loop detected — `<scenario>` fix applied but error persists. Manual investigation needed." |

## 关联资源

- `~/.openclaw/openclaw.json` — OpenClaw 主配置 (provider、model、超时、agent 默认值)
- `~/.openclaw/agents/<name>/agent/auth-profiles.json` — per-agent API key 配置
- `~/.openclaw/logs/gateway.log` — gateway reload / error 日志
- `~/.hermes/skills/devops/hermes-model-config/SKILL.md` — Hermes 侧 model 配置诊断 (provider 冲突、内置覆盖、`api_key_env` 解析)
- `~/.hermes/skills/devops/hermes-model-config/scripts/diagnose-provider-source.py` — provider source 矩阵诊断
- Anthropic API 状态: `https://status.anthropic.com`
- OpenAI API 状态: `https://status.openai.com`

