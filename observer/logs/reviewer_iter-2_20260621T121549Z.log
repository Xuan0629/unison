                prompt=prompt,
                workdir=info.path,
                timeout=self.spec.per_agent_timeout,
                log_path=log_path,
            )

            estimated_tokens = max(1, len(prompt) // 4)
            tracker.add_usage(
                estimated_tokens, phase=f"developer_{spec.role}", iter_n=iteration,
            )


