    workspace_rules: dict[Operation, RiskLevel] = field(default_factory=dict)
    external_rules: dict[Operation, RiskLevel] = field(default_factory=dict)

@dataclass(frozen=True)
class Stage:
    """DAG 中的一个阶段（V2 多 phase 并行）。

    Attributes:
