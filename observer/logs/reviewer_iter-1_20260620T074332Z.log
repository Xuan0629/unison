    41	def _env_value_patterns() -> list[tuple[str, str]]:
    42	    """Build patterns for current-os.environ API-key values.
    43	
    44	    Any value present in an os.environ key ending in ``_API_KEY`` is
    45	    treated as a secret and redacted wherever it appears.
    46	    """
    47	    patterns: list[tuple[str, str]] = []
    48	    for name, val in os.environ.items():
    49	        if val and (name.endswith("_API_KEY") or name.endswith("_SECRET")):
    50	            # Escape the literal value for use in a regex
    51	            escaped = re.escape(val)
    52	            patterns.append((escaped, _REDACTED))
    53	    return patterns
    54	
    55	
    56	def mask_secrets(text: str) -> str:
    57	    """Replace API keys and secrets in *text* with ``[REDACTED]``.
    58	
    59	    Covers these forms:
    60	
    61	    * ``sk-ant-...`` (Anthropic keys)
    62	    * ``sk-...`` (OpenAI / generic keys)
    63	    * ``Bearer <token>``
    64	    * ``api_key=<value>``
    65	    * ``<NAME>_API_KEY=<value>``
    66	    * ``<NAME>_SECRET=<value>``
    67	    * Any value found in an os.environ entry whose name ends in
    68	      ``_API_KEY`` or ``_SECRET``
    69	    """
    70	    for pattern, replacement in _SECRET_PATTERNS:
    71	        text = re.sub(pattern, replacement, text)
    72	
    73	    # Environment-value patterns are built at call time so they
    74	    # always reflect the current process environment.
    75	    for pattern, replacement in _env_value_patterns():
    76	        text = re.sub(pattern, replacement, text)
    77	
    78	    return text
