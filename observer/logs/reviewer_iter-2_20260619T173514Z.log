   764	    # ---- Internal --------------------------------------------------------
   765	
   766	    @staticmethod
   767	    def _validate_cli_binary(runtime_name: str, binary: str) -> None:
   768	        """Check that a CLI binary exists and is executable.
   769	
   770	        Runs ``binary --version`` with a 5s timeout. On failure, raises
   771	        PluginLoadError with a specific message.
   772	        """
   773	        try:
   774	            result = subprocess.run(
   775	                [binary, "--version"],
   776	                capture_output=True, text=True, timeout=5,
   777	            )
   778	            if result.returncode != 0:
   779	                raise PluginLoadError(
   780	                    runtime_name,
   781	                    f"'{binary} --version' exited with code "
   782	                    f"{result.returncode}. The binary may be broken."
   783	                )
   784	        except FileNotFoundError:
   785	            raise PluginLoadError(
   786	                runtime_name,
   787	                f"binary '{binary}' not found"
   788	            )
   789	        except subprocess.TimeoutExpired:
   790	            raise PluginLoadError(
   791	                runtime_name,
   792	                f"'{binary} --version' timed out after 5s"
   793	            )
   794	        except PermissionError:
   795	            raise PluginLoadError(
   796	                runtime_name,
   797	                f"'{binary}' is not executable (permission denied)"
   798	            )
