   670	    def _load_python_class(
   671	        self,
   672	        runtime_name: str,
   673	        module_name: str,
   674	        class_name: str,
   675	        search_paths: list[Path],
   676	    ) -> type[UnisonPlugin]:
   677	        """Find, import, and validate a Python plugin class.
   678	
   679	        Uses a deterministic import name derived from the runtime name
   680	        and a hash of the resolved file path. This prevents two plugins
   681	        with the same module filename from colliding in sys.modules.
   682	        """
   683	        module_file = f"{module_name}.py"
   684	
   685	        # Find the first matching file in search paths
   686	        found_path: Path | None = None
   687	        for sp in search_paths:
   688	            candidate = sp / module_file
   689	            if candidate.is_file():
   690	                found_path = candidate.resolve()
   691	                break
   692	
   693	        if found_path is None:
   694	            searched = ", ".join(str(p) for p in search_paths)
   695	            raise PluginLoadError(
   696	                runtime_name,
   697	                f"module '{module_file}' not found. "
   698	                f"Searched (in order): [{searched}]"
   699	            )
   700	
   701	        # Unique import name: runtime_name + hash of resolved path.
   702	        # Prevents sys.modules collisions when two plugins share a
   703	        # module filename (e.g. both named "runner.py").
   704	        path_hash = hashlib.sha256(
   705	            str(found_path).encode()
   706	        ).hexdigest()[:12]
   707	        unique_name = f"unison_plugin_{runtime_name}_{path_hash}"
   708	
   709	        spec = importlib.util.spec_from_file_location(
   710	            unique_name, str(found_path)
   711	        )
   712	        if spec is None or spec.loader is None:
   713	            raise PluginLoadError(
   714	                runtime_name,
   715	                f"could not create import spec for {found_path}"
   716	            )
   717	
   718	        module = importlib.util.module_from_spec(spec)
   719	        sys.modules[unique_name] = module
   720	        try:
   721	            spec.loader.exec_module(module)
   722	        except Exception as exc:
   723	            # Remove from sys.modules on failure so a retry can work
   724	            sys.modules.pop(unique_name, None)
   725	            raise PluginLoadError(
   726	                runtime_name,
   727	                f"error executing {found_path}: {exc}"
   728	            ) from exc
   729	
   730	        plugin_class = getattr(module, class_name, None)
   731	        if plugin_class is None:
   732	            raise PluginLoadError(
   733	                runtime_name,
   734	                f"class '{class_name}' not found in {found_path}"
   735	            )
   736	
   737	        if not issubclass(plugin_class, UnisonPlugin):
   738	            raise PluginLoadError(
   739	                runtime_name,
   740	                f"class '{class_name}' does not subclass UnisonPlugin"
   741	            )
   742	
   743	        return plugin_class
