   751	    def names(self) -> frozenset[str]:
   752	        """Return all registered plugin runtime names."""
   753	        return frozenset(self._plugins.keys())
   754	
   755	    def list_plugins(self) -> list[tuple[str, str, str]]:
   756	        """Return (runtime_name, class_name, binary) for validation output."""
   757	        result: list[tuple[str, str, str]] = []
   758	        for name, inst in self._plugins.items():
   759	            class_name = type(inst).__name__
   760	            binary = getattr(inst, "binary", "N/A")
   761	            result.append((name, class_name, binary))
