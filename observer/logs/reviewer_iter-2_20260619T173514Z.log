   261	    def _build_agents(
   262	        self, agents_raw: dict[str, Any]
   263	    ) -> dict[str, AgentSpec]:
   264	        """Build AgentSpec dict from raw YAML agent definitions."""
   265	        result: dict[str, AgentSpec] = {}
   266	        for key, ad in agents_raw.items():
   267	            if not isinstance(ad, dict):
   268	                raise PipelineValidationError(
   269	                    f"Agent '{key}' definition must be a mapping"
   270	                )
   271	
   272	            role = ad.get("role", "")
   273	            if not role:
   274	                raise PipelineValidationError(
   275	                    f"Agent '{key}' is missing required field: role"
   276	                )
   277	
   278	            runtime = ad.get("runtime", "")
   279	            if runtime not in self.VALID_RUNTIMES:
   280	                raise PipelineValidationError(
   281	                    f"Invalid runtime '{runtime}' for agent '{key}'"
   282	                )
   283	
   284	            result[role] = AgentSpec(
   285	                role=role,
   286	                runtime=runtime,
   287	                model=ad.get("model", ""),
   288	                system_prompt_path=Path(ad.get("system_prompt_path", "")),
   289	                task_instruction=ad.get("task_instruction"),
   290	                pipeline_role=ad.get("pipeline_role"),
   291	                context_budget=ad.get("context_budget"),
   292	            )
   293	        return result
