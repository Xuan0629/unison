   232	    def _validate_required_agents(self, agents_raw: dict[str, Any]) -> None:
   233	        """Check that all required pipeline roles are covered.
   234	
   235	        Each agent in *agents_raw* has an effective pipeline role:
   236	        ``pipeline_role`` if explicitly set, otherwise its ``role`` field.
   237	        At least one agent must map to each role in
   238	        ``REQUIRED_PIPELINE_ROLES``.
   239	        """
   240	        for required_role in self.REQUIRED_PIPELINE_ROLES:
   241	            found = False
   242	            for key, ad in agents_raw.items():
   243	                if not isinstance(ad, dict):
   244	                    continue
   245	                pr = ad.get("pipeline_role")
   246	                role = ad.get("role", "")
   247	                effective = pr if pr else role
   248	                if effective == required_role:
   249	                    found = True
   250	                    break
   251	            if not found:
   252	                raise PipelineValidationError(
   253	                    f"Missing required pipeline_role: {required_role!r}. "
   254	                    f"At least one agent must map to this role "
   255	                    f"(via role= or pipeline_role=). "
   256	                    f"Currently configured: {list(agents_raw.keys())}"
   257	                )
   258	
   259	    # -- builders ------------------------------------------------------
