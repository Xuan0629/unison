   872	def _select_runner(self, role: str) -> tuple:
   873	    ...
   874	    runner = self._runners.get(effective_spec.runtime)
   875	    if runner is None and self._plugin_registry is not None:
   876	        runner = self._plugin_registry.get(effective_spec.runtime)
   877	    if runner is None:
   878	        self.halt(f"No runner for runtime: {effective_spec.runtime}")
   879	        return None, None
   880	    return runner, effective_spec
