   190	    def mode(self, spec: PipelineSpec) -> str:
   191	        """返回 pipeline 模式：``"4-agent"`` 或 ``"2-agent"``。
   192	
   193	        Planner 存在 → ``"4-agent"``（Planner → Developer ↔ Reviewer → Observer）。
   194	        无 Planner → ``"2-agent"``（Developer ↔ Reviewer，向后兼容 V1）。
   195	
   196	        Args:
   197	            spec: A loaded ``PipelineSpec``.
   198	
   199	        Returns:
   200	            ``"4-agent"`` 如果 spec.agents 包含 planner，否则 ``"2-agent"``。
   201	        """
   202	        return "4-agent" if any(
   203	            a.effective_role == "planner" for a in spec.agents.values()
   204	        ) else "2-agent"
   205	
   206	    def dry_run(self, spec: PipelineSpec) -> bool:
   207	        """Check that every agent's prompt file exists on disk.
   208	
   209	        Args:
   210	            spec: A loaded ``PipelineSpec``.
   211	
   212	        Returns:
   213	            ``True`` when all prompt files are present.
   214	
   215	        Raises:
   216	            PipelineValidationError: If any prompt file is missing.
   217	        """
   218	        for role, agent in spec.agents.items():
   219	            prompt_path = spec.world.root / agent.system_prompt_path
   220	            if not prompt_path.is_file():
   221	                raise PipelineValidationError(
   222	                    f"Prompt file not found for '{role}': {prompt_path}"
   223	                )
