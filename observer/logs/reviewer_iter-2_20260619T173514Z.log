   334	
   335	```python
   336	# src/unison/plugins/cli_runner.py
   337	"""Internal runner that drives declarative CLI plugins (Tier 1).
   338	
   339	This is NOT a user-facing class — it's instantiated by PipelineLoader
   340	for each entry in ``cli_plugins:``. It wraps the user's binary + args
   341	in the same subprocess.run pattern as ClaudeRunner.
   342	"""
   343	from __future__ import annotations
   344	
   345	from dataclasses import dataclass, field
   346	from pathlib import Path
   347	from typing import ClassVar
   348	
   349	from unison.plugins.base import UnisonPlugin
   350	
   351	
   352	@dataclass
   353	class CLIPluginRunner(UnisonPlugin):
   354	    """Wraps a user-declared binary with args and env.
   355	
   356	    Instantiated programmatically — users don't subclass this.
   357	    They declare ``binary``, ``args``, ``env`` in ``cli_plugins:``.
   358	    """
   359	
   360	    binary: str = ""
   361	    cli_flags: list[str] = field(default_factory=list)
   362	    startup_grace: int = 0
   363	    _env: dict[str, str] = field(default_factory=dict)
   364	
   365	    @classmethod
   366	    def validate_installation(cls) -> tuple[bool, str | None]:
   367	        # CLIPluginRunner instances are validated at construction time
   368	        # by PluginRegistry._validate_cli_binary()
   369	        return True, None
   370	```
